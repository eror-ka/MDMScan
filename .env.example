# Скопируй этот файл в .env и заполни значения:
#   cp .env.example .env
# Сгенерировать пароли:
#   openssl rand -base64 24

PROJECT_NAME=mdmscan

# PostgreSQL
POSTGRES_USER=mdmscan
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=mdmscan

# MinIO
MINIO_ROOT_USER=mdmscan
MINIO_ROOT_PASSWORD=CHANGE_ME

# Telegram bots (получить токен у @BotFather)
BOT_TOKEN=CHANGE_ME
BOT_MINIAPP_TOKEN=CHANGE_ME

# URL веб-интерфейса (для мини-апп бота)
# Для Telegram Mini App (web_app кнопка) требуется HTTPS
# При HTTP бот автоматически использует обычную URL-кнопку
WEB_URL=http://YOUR_SERVER_IP:3000

# Очистка: сколько дней хранить сканы в MinIO и БД (Celery Beat + MinIO ILM)
SCAN_RETENTION_DAYS=5
